# Sanity Project Settings (आपके sanity.io/manage डैशबोर्ड से लिए गए)
NEXT_PUBLIC_SANITY_PROJECT_ID=vfq6y7fb
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Sanity API Token — यह आपको खुद बनाना होगा (नीचे README में तरीका है)
SANITY_API_TOKEN=your_sanity_token

# Webhook Revalidation Secret (कोई भी लंबा random string बना लें, जैसे: sarkaripatrika_secret_2026_xyz)
SANITY_REVALIDATE_SECRET=your_random_secret_string

# साइट का लाइव डोमेन
NEXT_PUBLIC_SITE_URL=https://officialsarkaripatrika.com

# Google Analytics 4 - Measurement ID (जैसे G-XXXXXXXXXX)
# analytics.google.com से Property बनाकर यहाँ ID डालें
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google AdSense अप्रूवल मिलने के बाद यहाँ अपना Publisher/Client ID डालें
# जैसे: ca-pub-1234567890123456
# जब तक यह खाली रहेगा, Ads Script लोड ही नहीं होगी - कोई नुकसान नहीं
NEXT_PUBLIC_ADSENSE_CLIENT_ID=

# Push Notification (Browser Notification) - VAPID Keys
# यह असली, इस्तेमाल के लिए तैयार keys हैं - बस इन्हें Vercel में डाल दें
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BOhn0ZMq8z5wStyekDClDjyy_UG5t0F2l9t4Q2Ewz6OWfOnaPMFBIu7ys-_pU7e5QdWbDZljL-rlmnL8KTh_lDg
VAPID_PRIVATE_KEY=2nIXPogZoHmTaJa9XrokY5hgJUBAemn-isRGa8Xlgck

# Google Indexing API - नई पोस्ट को तुरंत Google को बताने के लिए (वैकल्पिक)
# Google Cloud Console से Service Account बनाकर यहाँ डालें
GOOGLE_INDEXING_CLIENT_EMAIL=
GOOGLE_INDEXING_PRIVATE_KEY=
